# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=ventes_db

# API
API_PORT=3002
PORT=3002
NODE_ENV=production

# CORS - domaines autorisés (séparés par virgule) ou * pour tout
# Exemple: https://ventes.tondomaine.com,https://admin.tondomaine.com
CORS_ORIGIN=*

# Connection string complète (si besoin)
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ventes_db?schema=public

# CRM - URL de base pour les appels API proxy (recherche clients, etc.)
CRM_BASE_URL=https://crm.selfizee.com

# RabbitMQ - synchronisation depuis le CRM (consumer)
# Si non défini, le consumer est désactivé
RABBITMQ_URL=amqp://user:pass@host:5672/vhost
RABBITMQ_EXCHANGE=konitysevents
